# Vercel Postgres — automatically injected when you link a Vercel Postgres DB
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# Vercel KV — automatically injected when you link a Vercel KV store
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Password Protection ───────────────────────────────────────────────────────
# Set SITE_PASSWORD to enable the login gate on all pages except /api/raw/...
# Leave unset (or empty) to make the site fully public — useful for local dev.
SITE_PASSWORD=

# A secret salt used to derive the session token from the password.
# Change this to invalidate all existing sessions.
AUTH_SALT=change-me-to-a-random-string
